APP_NAME=EnterpriseMind
DATABASE_URL=postgresql+asyncpg://enterprisemind:enterprisemind@127.0.0.1:5432/enterprisemind
READONLY_DATABASE_URL=postgresql+asyncpg://enterprisemind_reader:reader-local-password@127.0.0.1:5432/enterprisemind
FRONTEND_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

JWT_SECRET=replace-with-a-long-random-value
JWT_ALGORITHM=HS256
ACCESS_TOKEN_MINUTES=30

QDRANT_URL=http://127.0.0.1:6333
QDRANT_COLLECTION=enterprise_knowledge_bge_m3_v1
EMBEDDING_DIMENSIONS=1024
OLLAMA_EMBEDDING_MODEL=bge-m3
OLLAMA_EMBEDDING_TIMEOUT_SECONDS=60
RETRIEVAL_MINIMUM_SCORE=0.20
RETRIEVAL_FULL_ANSWER_SCORE=0.45
RETRIEVAL_PARTIAL_ANSWER_SCORE=0.20
RETRIEVAL_MINIMUM_HIT_COUNT=1
RETRIEVAL_RERANK_CANDIDATES=8

REDIS_URL=redis://127.0.0.1:6379/0
UPLOAD_DIRECTORY=uploads
MAXIMUM_UPLOAD_BYTES=10485760

OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:3b
OLLAMA_TIMEOUT_SECONDS=120

EXTERNAL_MODEL_BASE_URL=https://api.deepseek.com/v1
EXTERNAL_MODEL_API_KEY=your-deepseek-api-key
EXTERNAL_MODEL_NAME=deepseek-v4-flash
EXTERNAL_MODEL_TIMEOUT_SECONDS=30

ALLOW_EXTERNAL_FOR_INTERNAL=false
SQL_MAX_ROWS=200
SQL_TIMEOUT_SECONDS=5

RQ_DOCUMENT_QUEUE=document_ingestion
RQ_JOB_TIMEOUT_SECONDS=300
RQ_RESULT_TTL_SECONDS=86400
EVALUATION_CASE_DIRECTORY=evaluation/cases
EVALUATION_MAXIMUM_DROP=0.03
