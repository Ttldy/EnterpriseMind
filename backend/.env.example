APP_NAME=EnterpriseMind
DATABASE_URL=postgresql+asyncpg://enterprisemind:enterprisemind@127.0.0.1:5432/enterprisemind
READONLY_DATABASE_URL=postgresql+asyncpg://enterprisemind_reader:reader-local-password@127.0.0.1:5432/enterprisemind

JWT_SECRET=replace-with-a-long-random-value
JWT_ALGORITHM=HS256
ACCESS_TOKEN_MINUTES=30

QDRANT_URL=http://127.0.0.1:6333
QDRANT_COLLECTION=enterprise_knowledge
EMBEDDING_DIMENSIONS=384
RETRIEVAL_MINIMUM_SCORE=0.20

REDIS_URL=redis://127.0.0.1:6379/0
UPLOAD_DIRECTORY=uploads
MAXIMUM_UPLOAD_BYTES=10485760

OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:3b
OLLAMA_TIMEOUT_SECONDS=120

EXTERNAL_MODEL_BASE_URL=https://api.deepseek.com/v1
EXTERNAL_MODEL_API_KEY=your-deepseek-api-key
EXTERNAL_MODEL_NAME=deepseek-v4-flash
EXTERNAL_MODEL_TIMEOUT_SECONDS=30

ALLOW_EXTERNAL_FOR_INTERNAL=false
SQL_MAX_ROWS=200
SQL_TIMEOUT_SECONDS=5