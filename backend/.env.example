APP_NAME=EnterpriseMind
DATABASE_URL=postgresql+asyncpg://enterprisemind:enterprisemind@127.0.0.1:5432/enterprisemind
READONLY_DATABASE_URL=postgresql+asyncpg://enterprisemind_reader:reader-local-password@127.0.0.1:5432/enterprisemind
FRONTEND_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

JWT_SECRET=replace-with-a-long-random-value
JWT_ALGORITHM=HS256
ACCESS_TOKEN_MINUTES=30

QDRANT_URL=http://127.0.0.1:6333
QDRANT_COLLECTION=enterprise_knowledge_bge_m3_v1
EMBEDDING_DIMENSIONS=1024
OLLAMA_EMBEDDING_MODEL=bge-m3
OLLAMA_EMBEDDING_TIMEOUT_SECONDS=60
RETRIEVAL_MINIMUM_SCORE=0.20
RETRIEVAL_FULL_ANSWER_SCORE=0.45
RETRIEVAL_PARTIAL_ANSWER_SCORE=0.20
RETRIEVAL_MINIMUM_HIT_COUNT=1
RETRIEVAL_RERANK_CANDIDATES=8
MEMORY_ENABLED=true
MEMORY_COLLECTION=enterprise_conversation_memory_v1
MEMORY_TOP_K=3
MEMORY_MINIMUM_SCORE=0.25
MEMORY_SUMMARY_TRIGGER_MESSAGES=6
MEMORY_SUMMARY_RECENT_MESSAGES=8
MEMORY_SUMMARY_MAX_CHARS=1200

REDIS_URL=redis://127.0.0.1:6379/0
UPLOAD_DIRECTORY=uploads
MAXIMUM_UPLOAD_BYTES=10485760

OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:3b
OLLAMA_TIMEOUT_SECONDS=120

EXTERNAL_MODEL_BASE_URL=https://api.deepseek.com/v1
EXTERNAL_MODEL_API_KEY=your-deepseek-api-key
EXTERNAL_MODEL_NAME=deepseek-v4-flash
EXTERNAL_MODEL_TIMEOUT_SECONDS=30

ALLOW_EXTERNAL_FOR_INTERNAL=false
SQL_MAX_ROWS=200
SQL_TIMEOUT_SECONDS=5

RQ_DOCUMENT_QUEUE=document_ingestion
RQ_JOB_TIMEOUT_SECONDS=300
RQ_RESULT_TTL_SECONDS=86400
EVALUATION_CASE_DIRECTORY=evaluation/cases
EVALUATION_MAXIMUM_DROP=0.03
EVALUATION_EXECUTOR_MODE=orchestrator
EVALUATION_JUDGE_ENABLED=true
EVALUATION_JUDGE_MINIMUM_SCORE=0.75
EVALUATION_JUDGE_FAIL_CLOSED=true
EVALUATION_JUDGE_MODEL_SENSITIVITY=internal
EVALUATION_DEFAULT_HR_USERNAME=hr01
EVALUATION_DEFAULT_IT_USERNAME=it01
EVALUATION_DEFAULT_FINANCE_USERNAME=finance01
EVALUATION_DEFAULT_EMPLOYEE_USERNAME=employee01
EVALUATION_DEFAULT_ADMIN_USERNAME=admin

INTENT_ROUTER_MODE=rule
TOOL_MANAGER_ENABLED=false
TOOL_DEFAULT_TIMEOUT_MS=3000
TOOL_DEFAULT_CACHE_TTL_SECONDS=30
TOOL_CIRCUIT_FAILURE_THRESHOLD=3
TOOL_CIRCUIT_RECOVERY_SECONDS=30
COMPOSITE_AGENT_ENABLED=false
MONITOR_ENABLED=false
BENCHMARK_OUTPUT_DIR=evaluation/reports
BENCHMARK_JUDGE_ENABLED=true
BENCHMARK_JUDGE_MINIMUM_SCORE=0.75
