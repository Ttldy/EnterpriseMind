{
  "name": "enterprisemind-frontend",
  "private": true,
  "version": "0.3.0",
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "npm-run-all typecheck build-only",
    "build-only": "vite build",
    "typecheck": "vue-tsc --build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write src e2e",
    "e2e": "playwright test"
  },
  "dependencies": {
    "axios": "1.18.0",
    "element-plus": "2.14.2",
    "pinia": "3.0.4",
    "vue": "3.5.38",
    "vue-router": "5.1.0"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@pinia/testing": "1.0.3",
    "@playwright/test": "1.61.0",
    "@types/node": "24.13.2",
    "@tsconfig/node22": "22.0.5",
    "@vitejs/plugin-vue": "6.0.7",
    "@vue/test-utils": "2.4.11",
    "@vue/tsconfig": "0.9.1",
    "eslint": "10.5.0",
    "eslint-plugin-vue": "10.9.2",
    "globals": "17.6.0",
    "happy-dom": "20.10.6",
    "npm-run-all2": "9.0.2",
    "prettier": "3.8.4",
    "typescript": "6.0.3",
    "typescript-eslint": "8.61.1",
    "vite": "8.0.16",
    "vitest": "4.1.9",
    "vue-tsc": "3.3.5"
  }
}